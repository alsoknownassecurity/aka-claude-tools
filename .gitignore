# Local, machine-, or user-specific — never commit
# repo-local agent working state (backlog, loop-guard) — not shipped
.claude/
aka-claude-tools.config
claude-tools.config
*.local
.DS_Store

# Dev-only typecheck deps (the hooks run with zero dependencies; node_modules
# exists only for `tsc` — see package.json). bun.lock IS committed for reproducible CI.
node_modules/

# Editor noise
.idea/
.vscode/
*.swp

# Never let a real config folder or secrets land in the repo
.claude-*/
.env
.credentials.json

# Local agent campaign state (backlog, done-log, cleared markers) — never commit
.claude/
